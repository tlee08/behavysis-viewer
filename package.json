    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.9.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^5.4.21"
